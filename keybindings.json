      "command": "-cursorDown",
      "when": "textInputFocus"
   },
   {
      "key": "ctrl+n",
      "command": "-list.focusDown",
      "when": "listFocus && !inputFocus && !treestickyScrollFocused"
   },
   {
      "key": "ctrl+n",
      "command": "-selectNextCodeAction",
      "when": "codeActionMenuVisible"
   },
   {
      "key": "ctrl+n",
      "command": "-selectNextSuggestion",
