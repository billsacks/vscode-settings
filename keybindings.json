   // Get rid of standard ctrl+p / ctrl+n shortcuts (can use up/down arrows for that); use
   // ctrl+. and ctrl+p for navigating tabs
   {
      "key": "ctrl+p",
      "command": "-workbench.action.quickOpenSelectPrevious",
      "when": "inQuickOpen"
   },
